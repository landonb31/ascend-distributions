# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ascend Distributions

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (for npm run setup:db)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STANDARD_MONTHLY=price_...
STRIPE_PRICE_STANDARD_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Resend (app transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Ascend Distributions <noreply@ascenddistributions.com>
CONTACT_EMAIL=support@ascenddistributions.com

# Ascend Systems Ecosystem
NEXT_PUBLIC_ASCEND_SYSTEMS_URL=https://ascendsystems.com

# Distribution (FUGA — required for store delivery)
# Sign up at https://fuga.com and request API + white-label access
DISTRIBUTION_PROVIDER=fuga
FUGA_API_URL=https://next.fugamusic.com/api/v2
FUGA_USERNAME=
FUGA_PASSWORD=
FUGA_LABEL_ID=
FUGA_DEFAULT_SUBGENRE_ID=1
# Comma-separated DSP IDs from your FUGA account (Spotify, Apple Music, etc.)
FUGA_DELIVERY_DSPS=

# FUGA webhooks (optional — for live delivery status updates)
FUGA_WEBHOOK_USERNAME=
FUGA_WEBHOOK_PASSWORD=

# Cron secret for /api/cron/distribute (set in Vercel Cron)
CRON_SECRET=
